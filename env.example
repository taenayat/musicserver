# ── Host ──────────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000

# ── Navidrome admin account ───────────────────────────────────────────────────
# Created on Navidrome's first launch. The gateway uses these internally to
# trigger library scans. Every Navidrome account also works as a Symfonium login.
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASS=change-me

# ── Deezer ARL ────────────────────────────────────────────────────────────────
# Log into Deezer in a browser, open dev tools → Application → Cookies, and copy
# the value of the `arl` cookie here. If it's invalid/expired the gateway logs
# "Deezer ARL INVALID" on startup and downloads won't work.
DEEZER_ARL=your-deezer-arl-cookie-here

# ── Gateway API key ───────────────────────────────────────────────────────────
# Single shared secret for the web UI and REST API. Enter it once in the web app
# (it is then saved in the browser). Generate a fresh one with:
#   python3 -c "import secrets; print(secrets.token_hex(24))"
GATEWAY_API_KEY=generate-a-random-string-here

# ── Downloads ─────────────────────────────────────────────────────────────────
# Requested download quality: FLAC, 320, or 128. deemix falls back to a lower
# bitrate automatically, so 320 safely degrades to 128 on Free/standard accounts.
# Only HiFi accounts can actually fetch FLAC.
DEEMIX_BITRATE=320

# ── Host ──────────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000

# ── Navidrome admin account ───────────────────────────────────────────────────
# Created on Navidrome's first launch. The gateway uses these internally to
# trigger scans and manage user accounts. Every Navidrome account also works as
# a Symfonium login. Manage all accounts in the gateway admin panel — never
# change passwords directly in Navidrome.
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASS=change-me

# ── Deezer / deemix ───────────────────────────────────────────────────────────
# Log into Deezer in a browser, open dev tools → Application → Cookies, and copy
# the value of the `arl` cookie here. If it's invalid/expired the gateway logs
# "Deezer ARL INVALID" on startup and downloads won't work.
DEEZER_ARL=your-deezer-arl-cookie-here
DEEMIX_BITRATE=320              # 320 (degrades to 128 on Free), FLAC for HiFi

# ── Gateway security ──────────────────────────────────────────────────────────
# Fernet key used to encrypt stored Navidrome passwords. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GATEWAY_SECRET_KEY=

# ── Telegram cold storage ─────────────────────────────────────────────────────
# Create a bot via @BotFather, create a private channel, add the bot as admin.
# Leave blank to disable Telegram backup (cache eviction then stays off).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=            # e.g. -1001234567890

# ── Features ──────────────────────────────────────────────────────────────────
YTDLP_ENABLED=true
# YouTube blocks datacenter IPs with a "confirm you're not a bot" wall, which
# breaks downloads (search works without this). Export cookies.txt from a
# logged-in browser, drop it in ./data/, and point this at it:
YTDLP_COOKIES_FILE=             # e.g. /data/youtube-cookies.txt
LYRICS_ENABLED=true
GENIUS_API_KEY=                 # Optional. lrclib is used regardless.

# ── Radio ─────────────────────────────────────────────────────────────────────
RADIO_ENABLED=true
RADIO_TRACK_COUNT=20
RADIO_TTL_HOURS=24

# ── Hot cache ─────────────────────────────────────────────────────────────────
CACHE_SIZE_GB=20
CACHE_ENABLED=false            # Set true after Telegram is confirmed working
CACHE_EVICTION_POLICY=hybrid   # lru | lfu | hybrid
CACHE_PIN_FAVORITES=true
CACHE_PIN_RECENT_DAYS=7
CACHE_MIN_PLAY_COUNT=3
